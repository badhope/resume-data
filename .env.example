# Application
DEBUG=false
SECRET_KEY=your-secret-key-change-in-production-please
APP_NAME=Resume Cleaner
APP_VERSION=1.0.0

# Database
DATABASE_URL=sqlite:///./data/resume_cleaner.db

# JWT Settings
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# WeChat Integration
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret

# Email Settings (Optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your_smtp_password

# Shipping API Keys
SF_EXPRESS_KEY=your_sf_key
SF_EXPRESS_SECRET=your_sf_secret

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3007

# File Upload
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=.pdf,.doc,.docx,.txt,.html
